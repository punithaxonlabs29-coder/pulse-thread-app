{
  "expo": {
    "name": "pulse thread",
    "slug": "pulse thread",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pulse_threads_app_icon.png",
    "scheme": "pulsethread",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#FFFFFF",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/pulse_threads_app_icon.png",
        "monochromeImage": "./assets/images/pulse_threads_app_icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.pulsethread",

      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/pulse_thread.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/pulse_thread.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./withNotifee.js",
      "./withFontScaleConfig.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
